pipeline{
    agent any

    stages{
        stage('Build'){
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
            sh'''

            echo "Start my first pipeline"
            ls -la
            node --version
            npm ci
            npm run build
            ls -la
            '''
            }
        }

    }
}

