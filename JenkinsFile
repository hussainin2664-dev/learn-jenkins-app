pipeline{
    agent any

    stages{
        stage('Build'){
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps{
            sh'''

            echo "Start my first pipeline"
            ls -la
            node --version
            npm ci
            npm run build
            ls -la
            '''
            }
        }
    
    stage('Test'){
        steps{

            sh'''

                echo "Start Test Stage"
                test -f build/index.html && echo "File exists" || echo "File does not exists"

            '''
        }
    }

    }
}

